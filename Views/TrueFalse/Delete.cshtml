@model QuizApp.Models.TrueFalse

@{
    ViewData["Title"] = "Delete True/False Question";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center text-danger">Delete True/False Question</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <p class="fw-semibold mb-2">Are you sure you want to delete this question?</p>

            <div class="border rounded p-3 bg-light">
                <strong>@Model.QuestionText</strong>
            </div>

            <div class="mt-3">
                <p><strong>Correct Answer:</strong> @(Model.CorrectAnswer ? "True" : "False")</p>
            </div>
        </div>
    </div>

    <form 
        asp-action="DeleteConfirmed" 
        asp-route-questionId="@Model.TrueFalseId"
        asp-route-qNum="@Model.QuizQuestionNum"
        asp-route-quizId="@Model.QuizId"> 
        <button type="submit" class="btn btn-danger me-2">Delete</button>
        <a asp-controller="Quiz" asp-action="ManageQuiz" asp-route-quizId="@Model.QuizId" class="btn btn-secondary">Cancel</a>
    </form>
</div>
