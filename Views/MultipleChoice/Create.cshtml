@model QuizApp.Models.MultipleChoice

@{
    ViewData["Title"] = "Add Multiple Choice Question";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Add Multiple Choice Question</h2>

    <form asp-action="Create" method="post" class="card p-4 shadow-sm">
        <input type="hidden" asp-for="MultipleChoiceId" />
        <input type="hidden" asp-for="QuizId" />
        <input type="hidden" asp-for="QuizQuestionNum" />
        <input type="hidden" asp-for="CorrectAnswer" />


        <div class="mb-3">
            <label asp-for="QuestionText" class="form-label fw-bold">Question</label>
            <input asp-for="QuestionText" class="form-control" placeholder="Enter your question here" />
            <span asp-validation-for="QuestionText" class="text-danger"></span>
        </div>

        <h5 class="mt-3">Options</h5>
    @for (int i = 0; i < Model.Options.Count; i++)
    {
        <div class="row align-items-center mb-2">
            <div class="col-md-8">
                <input type="hidden" name="Options[@i].OptionId" value="@Model.Options[i].OptionId" />
                <input name="Options[@i].Text"
                       class="form-control"
                       placeholder="Enter option @(i + 1)..."
                       value="@Model.Options[i].Text" />
            </div>
            <div class="col-md-4 d-flex align-items-center">
                <input name="Options[@i].IsCorrect"
                       type="checkbox"
                       class="form-check-input me-2"
                       value="true"
                       @(Model.Options[i].IsCorrect ? "checked" : "") />
                <label class="form-check-label">Correct</label>
            </div>
        </div>
    }

        <div class="mt-4 text-end">
            <button type="submit" class="btn btn-primary me-2">Save</button>
            <a asp-controller="Quiz" asp-action="ManageQuiz" asp-route-quizId="@Model.QuizId" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
