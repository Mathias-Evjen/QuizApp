@using Microsoft.Extensions.ObjectPool
@model QuizApp.ViewModels.RankingViewModel
@{
    ViewData["Title"] = "Show Ranking Questions";
    
}

<h1>Ranking Questions</h1>
<hr />
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Question Text</th>
            <th>Question</th>
            <th>Correct Answer</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ranking in Model.Rankings)
        {
            <tr>
                <td>@ranking.Id</td>
                <td>@ranking.QuestionText</td>
                <td>
                    @{
                        string[] questionSplit = ranking.Question.Split(",");
                        string questionFormatted = "";
                        for(int i = 0; i < questionSplit.Length; i++){
                            if (i != 0){questionFormatted+=" - ";}
                            questionFormatted+=questionSplit[i];
                        }
                    }
                    @questionFormatted
                </td>
                <td>
                    @{
                        string[] correctAnswerSplit = ranking.CorrectAnswer.Split(",");
                        string correctAnswerFormatted = "";
                        for(int i = 0; i < correctAnswerSplit.Length; i++){
                            if (i != 0){correctAnswerFormatted+=" -> ";}
                            correctAnswerFormatted+=correctAnswerSplit[i];
                        }
                    }
                    @correctAnswerFormatted
                </td>
                <td>
                    <a asp-action="UpdateRankingPage" asp-route-id="@ranking.Id" class="btn btn-primary" style="margin-bottom: 5px;">Update</a>
                    <br />
                    <a asp-action="DeleteRanking" asp-route-id="@ranking.Id" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
</div>