@model (MultipleChoice mc, MultipleChoiceAttempt mcAttempt)

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h5 class="card-subtitle text-muted mb-2">Question @Model.mc.QuizQuestionNum</h5>
        <h4 class="card-title fw-semibold mb-3">@Model.mc.QuestionText</h4>

        <div class="mt-3">
            <p><strong>Your answer:</strong> @Model.mcAttempt.UserAnswer</p>

            @if (Model.mcAttempt.AnsweredCorrectly.HasValue)
            {
                if (Model.mcAttempt.AnsweredCorrectly.Value)
                {
                    <div class="alert alert-success d-flex align-items-center" role="alert">
                        <span>Correct!</span>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <span>Wrong. The correct answer was <strong>@Model.mc.CorrectAnswer</strong>.</span>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-secondary" role="alert">
                    Not answered yet.
                </div>
            }
        </div>
    </div>
</div>
