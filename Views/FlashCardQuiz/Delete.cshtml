@model FlashCardQuiz

<h2>Delete Flash Card</h2>

<h3>Are you sure you want to delete this fill in the Flash Card?</h3>
<div>
    <h4>Flash Card</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.FlashCardQuizId</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>
    </dl>

    <table>
        <tr>
            <th>No.</th>
            <th>Questions</th>
            <th>Answer</th>
        </tr>
        @foreach(var flashCard in Model.FlashCards)
        {
            <tr>
                <td>@flashCard.FlashCardId</td>
                <td>@flashCard.Question</td>
                <td>@flashCard.Answer</td>
            </tr>
        }
    </table>

    <form asp-action="DeleteConfirmed" asp-route-id="@Model.FlashCardQuizId">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="FlashCards" class="btn btn-secondary">Cancel</a>
    </form>
</div>