@model IEnumerable<QuizApp.Models.TrueFalseQuestion>

@{
    ViewData["Title"] = "True/False Questions";
}

<h2>True/False Questions</h2>

<p>
    <a class="btn btn-success" asp-action="Create">Add New Question</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Question</th>
            <th>Answer</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.QuestionText</td>
                <td>@(item.CorrectAnswer ? "True" : "False")</td>
                <td>
                    <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
