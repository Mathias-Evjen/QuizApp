@model QuizApp.Models.Quiz

@{
    ViewData["Title"] = "Create Matching Questions";
    var quizQuestionNum = Model.NumOfQuestions+1;
}

<div class="container">
    <h1>Opprett Matching Question</h1>
    <hr />
    <form asp-action="CreateMatchingQuestion" asp-controller="Matching" method="post" id="matchingForm">
        <input type="hidden" name="quizId" value="@Model.QuizId" />
        <input type="hidden" name="quizQuestionNum" value="@quizQuestionNum" />

        <div id="keyValueContainer">
            <input type="text" class="form-control" style="max-width:50vw;" name="questionText" placeholder="Question text..."/><br />
            <div class="row mb-3">
                <div class="col-5">
                    <input type="text" class="form-control" name="Keys" placeholder="Key" />
                </div>
                <div class="col-5">
                    <input type="text" class="form-control" name="Values" placeholder="Value" />
                </div>
                <div class="col-2">
                    <button type="button" class="btn btn-danger remove-pair" onclick="removePair(this)">X</button>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-secondary mb-3" id="addPairButton">Add row</button>
        <br><br>
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-controller="Quiz" asp-action="ManageQuiz" asp-route-quizId="@Model.QuizId" class="btn btn-secondary">Cancel</a>
    </form>
</div>

<script>
    // Legg til dynamiske Key/Value-par
    document.getElementById('addPairButton').addEventListener('click', function () {
        const container = document.getElementById('keyValueContainer');

        // Opprett en ny rad med Key/Value-inputfelt
        const newRow = document.createElement('div');
        newRow.classList.add('row', 'mb-3');
        newRow.innerHTML = `
            <div class="col-5">
                <input type="text" class="form-control" name="Keys" placeholder="Key" />
            </div>
            <div class="col-5">
                <input type="text" class="form-control" name="Values" placeholder="Value" />
            </div>
            <div class="col-2">
                <button type="button" class="btn btn-danger remove-pair" onclick="removePair(this)">X</button>
            </div>
        `;
        container.appendChild(newRow);
    });

    // Fjern en eksisterende Key/Value-par
    function removePair(button) {
        const row = button.parentElement.parentElement;
        row.remove();
    }
</script>