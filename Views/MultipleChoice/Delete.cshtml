@model QuizApp.Models.MultipleChoice

@{
    ViewData["Title"] = "Delete Multiple Choice";
}

<h2>Delete Multiple Choice Question</h2>

<p>Are you sure you want to delete this question?</p>

<p><strong>@Model.QuestionText</strong></p>

@if (Model.Options != null && Model.Options.Any())
{
    <ul>
        @foreach (var opt in Model.Options)
        {
            <li>
                @opt.Text
                @if (opt.IsCorrect)
                {
                    <span style="color: green; font-weight: bold;">(Correct)</span>
                }
            </li>
        }
    </ul>
}
else
{
    <p class="text-muted">No options for this question.</p>
}

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="MultipleChoiceId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

