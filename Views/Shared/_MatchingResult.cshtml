@model (Matching matching, MatchingAttempt matchingAttempt)

@{
    var splitQuestion = Model.matching.SplitQuestion();
    string formattedQuestion = "";
    for(int i = 0; i < splitQuestion.Length; i++){
        formattedQuestion += splitQuestion[i].Key + " <=> " + splitQuestion[i].Value + "   ";
    }
    var splitCorrectAnswer = Model.matching.SplitCorrectAnswer();
    string formattedCorrectAnswer = "";
    for(int i = 0; i < splitCorrectAnswer.Length; i++){
        formattedCorrectAnswer += splitCorrectAnswer[i].Key + " <=> " + splitCorrectAnswer[i].Value + "   ";
    }
}

<div>
    <h3>Question @Model.matching.QuizQuestionNum</h3>
    <h4>@Model.matching.QuestionText</h4>
    <h5>Your answer:</h5>
    <p>@formattedQuestion</p>
    <h5>Amount correct: @Model.matchingAttempt.AmountCorrect</h5>
    @if (Model.matchingAttempt.AnsweredCorrectly.HasValue) 
    {
        <div class="mt-3 alert @(Model.matchingAttempt.AnsweredCorrectly.Value ? "alert-success" : "alert-dagner")">
            @(Model.matchingAttempt.AnsweredCorrectly.Value ? "Correct!" : $"Wrong. The correct answer was '{formattedCorrectAnswer}'")
        </div>
    }
</div>
