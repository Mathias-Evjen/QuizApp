@model IEnumerable<QuizApp.Models.TrueFalseQuestion>

<h2>True / False Questions</h2>

<a asp-action="Create" class="btn btn-primary mb-3">+ Add Question</a>

<table class="table table-bordered align-middle">
    <thead class="table-light">
        <tr>
            <th>Question</th>
            <th>Correct Answer</th>
            <th style="width: 220px;">Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var q in Model)
    {
        <tr>
            <td>@q.QuestionText</td>
            <td>@(q.CorrectAnswer ? "True" : "False")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@q.Id" class="btn btn-sm btn-warning me-2">Edit</a>
                <form asp-action="Delete" asp-route-id="@q.Id" method="post" style="display:inline;" 
                      onsubmit="return confirm('Are you sure you want to delete this question?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
