@model QuizApp.Models.FillInTheBlank

<h2>Delete Question</h2>

<h3>Ar/em> you sure you want to delete this fill in the blank-question?</h3>
<div>
    <h4>Question</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.QuestionId</dd>

        <dt class="col-sm-2">Question</dt>
        <dd class="col-sm-10">@Model.Question</dd>

        <dt class="col-sm-2">Answer</dt>
        <dd class="col-sm-10">@Model.Answer</dd>
    </dl>

    <form asp-action="DeleteConfirmed" asp-route-id="@Model.QuestionId">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Questions" class="btn btn-secondary">Cancel</a>
    </form>
</div>