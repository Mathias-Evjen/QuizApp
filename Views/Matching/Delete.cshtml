@model QuizApp.Models.Matching

<h2>Delete Question</h2>

<h3>Are you sure you want to delete this matching-question?</h3>
<div>
    <h4>Question</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Question</dt>
        <dd class="col-sm-10">@Model.Question</dd>

        <dt class="col-sm-2">Answer</dt>
        <dd class="col-sm-10">@Model.CorrectAnswer</dd>
    </dl>

    <form 
        asp-action="DeleteConfirmed" 
        asp-route-questionId="@Model.Id"
        asp-route-qNum="@Model.QuizQuestionNum"
        asp-route-quizId="@Model.QuizId">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Questions" class="btn btn-secondary">Cancel</a>
    </form>
</div>