@model List<QuizApp.Models.MultipleChoice>

@{
    ViewData["Title"] = "Multiple Choice Questions";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Multiple Choice Questions</h2>
        <a asp-action="Create" class="btn btn-success">+ Add Question</a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info" role="alert">
            No multiple choice questions have been added yet.
        </div>
    }
    else
    {
        @foreach (var q in Model)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <!-- Spørsmålstekst -->
                    <h5 class="card-title">@q.QuestionTexts</h5>

                    <!-- Alternativer -->
                    @if (q.Options != null && q.Options.Any())
                    {
                        <ul class="list-group list-group-flush mb-3">
                            @foreach (var opt in q.Options)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    @opt.Text
                                    @if (opt.IsCorrect)
                                    {
                                        <span class="badge bg-success">Correct</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted">No options available</p>
                    }

                    <!-- Handlingsknapper -->
                    <div class="text-end">
                        <a asp-action="Edit" asp-route-id="@q.Id" class="btn btn-sm btn-primary me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@q.Id" class="btn btn-sm btn-danger">Delete</a>
                    </div>
                </div>
            </div>
        }
    }
</div>
