@model QuizApp.ViewModels.FlashCardsViewModel

<input type="hidden" name="CurrentFlashCardNum" value="@Model.CurrentFlashCardNum" />
<input type="hidden" name="FlashCardQuizName" value="@Model.FlashCardQuizName" />
<input type="hidden" name="FlashCardQuizDescription" value="@Model.FlashCardQuizDescription" />
@foreach (var card in Model.FlashCards.Select((c, index) => (c, index)))
{
    <input type="hidden" name="FlashCards[@card.index].FlashCardId" value="@card.c.FlashCardId" />
    <input type="hidden" name="FlashCards[@card.index].Question" value="@card.c.Question" />
    <input type="hidden" name="FlashCards[@card.index].Answer" value="@card.c.Answer" />
    <input type="hidden" name="FlashCards[@card.index].ShowAnswer" value="@card.c.ShowAnswer.ToString().ToLower()" />
    <input type="hidden" name="FlashCards[@card.index].BackgroundColor" value="@card.c.BackgroundColor" />
}