                        if(i!=0){questionFormatted+=" , ";}
                        questionFormatted += questionSplit[i] + " <-> " + questionSplit[i+1];
                    }
                }
                @questionFormatted
                </td>
                <td>
                @{
                    string correctAnswerFormatted = "";
                    string[] correctAnswerSplit = matching.CorrectAnswer.Split(",");
                    for(int i = 0; i < correctAnswerSplit.Length; i+=2){
                        if(i!=0){correctAnswerFormatted+=" , ";}
                        correctAnswerFormatted += correctAnswerSplit[i] + " <-> " + correctAnswerSplit[i+1];
                    }
                }
                @correctAnswerFormatted
                </td>
                <td>
                    <a asp-action="UpdateMatchingPage" asp-route-id="@matching.Id" class="btn btn-primary" style="margin-bottom: 5px;">Update</a>
                    <br />
                    <a asp-action="DeleteMatching" asp-route-id="@matching.Id" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>
</div> *@