@model List<QuizApp.Models.TrueFalseQuestion>

<h2>True/False Questions</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Add Question</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Question</th>
            <th>Correct Answer</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var q in Model)
    {
        <tr>
            <td>@q.QuestionText</td>
            <td>@(q.CorrectAnswer ? "True" : "False")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@q.Id" class="btn btn-primary btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@q.Id" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
