@model QuizApp.Models.MultipleChoice

@{
    ViewData["Title"] = "Create Multiple Choice";
}

<h2>Add New Multiple Choice Question</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="QuestionText" class="form-label"></label>
        <input asp-for="QuestionText" class="form-control" />
        <span asp-validation-for="QuestionText" class="text-danger"></span>
    </div>

    <h5>Options</h5>
    <div id="options-container">
        <div class="mb-2">
            <input name="optionTexts" class="form-control" placeholder="Option text" />
            <input type="checkbox" name="correctOptionIndexes" value="0" /> Correct
        </div>
    </div>

    <button type="button" class="btn btn-secondary mb-3" id="add-option">Add Option</button>
    <button type="submit" class="btn btn-primary">Save</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let optionIndex = 1;
        document.getElementById("add-option").addEventListener("click", function () {
            const container = document.getElementById("options-container");
            const div = document.createElement("div");
            div.className = "mb-2";
            div.innerHTML = `
                <input name="optionTexts" class="form-control" placeholder="Option text" />
                <input type="checkbox" name="correctOptionIndexes" value="${optionIndex}" /> Correct
            `;
            optionIndex++;
            container.appendChild(div);
        });
    </script>
}
