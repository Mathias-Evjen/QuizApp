@* @using Microsoft.Extensions.ObjectPool
@model QuizApp.ViewModels.MatchingViewModel

@{
    ViewData["Title"] = "Show Matching Questions";
    
}

<h1>Matching Questions</h1>
<hr />
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Question</th>
            <th>Correct Answer</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var matching in Model.Matchings)
        {
