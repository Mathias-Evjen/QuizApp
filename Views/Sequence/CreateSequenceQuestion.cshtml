@model QuizApp.ViewModels.SequenceViewModel

@{
    ViewData["Title"] = "Create Sequence Questions";
}

<div class="container">
    <h1>Create sequence question in order</h1>
    <hr />
    <form asp-action="CreateSequenceQuestion" method="post" id="sequenceForm">
        <div id="valuesContainer">
            <div class="row mb-3">
                <div class="col-5">
                    <input type="text" class="form-control" name="Values" placeholder="Value" />
                </div>
                <div class="col-2">
                    <button type="button" class="btn btn-danger remove-row" onclick="removeRow(this)">X</button>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-secondary mb-3" id="addRow">Add row</button>
        <br><br>
        <button type="submit" class="btn btn-primary">Save</button>
    </form>
</div>

<script>
    // Legg til dynamiske Key/Value-par
    document.getElementById('addRow').addEventListener('click', function () {
        const container = document.getElementById('valuesContainer');

        // Opprett en ny rad med Key/Value-inputfelt
        const newRow = document.createElement('div');
        newRow.classList.add('row', 'mb-3');
        newRow.innerHTML = `
            <div class="col-5">
                <input type="text" class="form-control" name="Values" placeholder="Value" />
            </div>
            <div class="col-2">
                <button type="button" class="btn btn-danger remove-pair" onclick="removeRow(this)">X</button>
            </div>
        `;
        container.appendChild(newRow);
    });

    // Fjern en eksisterende Key/Value-par
    function removeRow(button) {
        const row = button.parentElement.parentElement;
        row.remove();
    }
</script>