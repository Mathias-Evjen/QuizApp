@model QuizApp.Models.TrueFalseQuestion

<h2>Create True/False Question</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="QuestionText" class="form-label"></label>
        <input asp-for="QuestionText" class="form-control" />
        <span asp-validation-for="QuestionText" class="text-danger"></span>
    </div>

    <div class="form-check">
        <input asp-for="CorrectAnswer" class="form-check-input" type="checkbox" />
        <label asp-for="CorrectAnswer" class="form-check-label">Correct Answer is True</label>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>
