@model (TrueFalse tf, TrueFalseAttempt tfAttempt)

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h5 class="card-subtitle text-muted mb-2">Question @Model.tf.QuizQuestionNum</h5>
        <h4 class="card-title fw-semibold mb-3">@Model.tf.QuestionText</h4>

        <div class="mt-3">
            <p><strong>Your Answer:</strong> @(Model.tfAttempt.UserAnswer ? "True" : "False")</p>

            @if (Model.tfAttempt.AnsweredCorrectly.HasValue)
            {
                if (Model.tfAttempt.AnsweredCorrectly.Value)
                {
                    <div class="alert alert-success d-flex align-items-center" role="alert">
                        <span>Correct!</span>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <span>Wrong. The right answer was <strong>@(Model.tf.CorrectAnswer ? "True" : "False")</strong>.</span>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-secondary" role="alert">
                    Not answered yet.
                </div>
            }
        </div>
    </div>
</div>
