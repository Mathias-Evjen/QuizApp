@model QuizApp.Models.TrueFalse

@{
    ViewData["Title"] = "Add True/False Question";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Add True/False Question</h2>

    <form asp-action="Create" method="post" class="card p-4 shadow-sm">
        <input type="hidden" asp-for="QuizId" />
        <input type="hidden" asp-for="QuizQuestionNum" />
        <div class="mb-3">
            <label asp-for="QuestionText" class="form-label fw-bold">Question</label>
            <input asp-for="QuestionText" class="form-control" placeholder="Enter the question text..." />
            <span asp-validation-for="QuestionText" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" asp-for="CorrectAnswer" />
            <label asp-for="CorrectAnswer" class="form-check-label fw-semibold">Question is True</label>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-success me-2">Save</button>
            <a asp-controller="Quiz" asp-action="ManageQuiz" asp-route-quizId="@Model.QuizId" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
