@model QuizApp.Models.FillInTheBlank

<h2>Edit question</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="FillInTheBlankId" />
    <input type="hidden" asp-for="QuizId" />
    <input type="hidden" asp-for="QuizQuestionNum" />
    <div class="form-group">
        <label asp-for="Question">Question:</label>
        <input asp-for="Question" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="CorrectAnswer">Answer:</label>
        <input asp-for="CorrectAnswer" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save changes</button>
    <a asp-controller="Quiz" asp-action="ManageQuiz" asp-route-quizId="@Model.QuizId" class="btn btn-secondary">Cancel</a>
</form>