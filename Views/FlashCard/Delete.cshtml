@model FlashCard

<h2>Delete Flash Card</h2>

<h3>Are you sure you want to delete this fill in the Flash Card?</h3>
<div>
    <h4>Flash Card</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.FlashCardId</dd>

        <dt class="col-sm-2">Question</dt>
        <dd class="col-sm-10">@Model.Question</dd>

        <dt class="col-sm-2">Answer</dt>
        <dd class="col-sm-10">@Model.Answer</dd>
    </dl>

    <form asp-action="DeleteConfirmed" asp-route-flashCardId="@Model.FlashCardId" asp-route-qNum="@Model.QuizQuestionNum" asp-route-quizId="@Model.QuizId">
        <button type="submit" class="btn btn-danger mt-1">Delete</button>
        <a asp-action="FlashCards" class="btn btn-secondary mt-1">Cancel</a>
    </form>
</div>