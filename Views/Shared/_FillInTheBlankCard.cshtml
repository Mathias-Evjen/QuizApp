@model QuizApp.ViewModels.FillInTheBlankViewModel

<!-- Defines a prefix for where the values in the form should be mapped -->
<!-- Works in key-value pairs: questionVM.FillInTheBlankId = Model.FillInTheBlankId -->
<!-- This becomes Model.Questions[0].FillInTheBlankId=1 (if the value is set to 1) in the Questions razor view -->
@{
    var questionVM = ViewData["questionVM"]?.ToString() ?? "";
}

<div class="col">
    <div class="mt-2">
        <span>
            <h3 class="text-start">Question @Model.FillInTheBlankId</h3>
            <a asp-action="Edit" asp-route-id="@Model.FillInTheBlankId" class="btn btn-secondary">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.FillInTheBlankId" class="btn btn-danger">Delete</a>
        </span>
        <p>@Model.Question</p>

        <div class="form-group">
            <input type="hidden" name="@($"{questionVM}.FillInTheBlankId")" value="@Model.FillInTheBlankId" />
            <input type="hidden" name="@($"{questionVM}.Question")" value="@Model.Question" />

            <label for="@($"{questionVM}.UserAnswer")">Your Answer:</label>
            <input type="text" for="@($"{questionVM}.UserAnswer")" name="@($"{questionVM}.UserAnswer")" value="@Model.UserAnswer" class="form-control mb-2" />
            @if (Model.IsAnswerCorrect.HasValue) 
            {
                <div class="mt-3 alert @(Model.IsAnswerCorrect.Value ? "alert-success" : "alert-danger")">
                    @(Model.IsAnswerCorrect.Value ? "Correct!" : $"Wrong. The correct answer was '{@Model.CorrectAnswer}'")
                </div>
            }
        </div>
    </div>
</div>