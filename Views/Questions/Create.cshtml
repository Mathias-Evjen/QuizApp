@model QuizApp.Models.MultipleChoice

<h2>Add Multiple Choice Question</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="QuestionText" class="form-label"></label>
        <input asp-for="QuestionText" class="form-control" />
        <span asp-validation-for="QuestionText" class="text-danger"></span>
    </div>

    <h5>Options</h5>
    @for (int i = 0; i < Model.Options.Count; i++)
    {
        <div class="mb-2">
            <input asp-for="Options[i].Text" class="form-control" placeholder="Option text" />
            <input asp-for="Options[i].IsCorrect" type="checkbox" /> Correct
        </div>
    }

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
