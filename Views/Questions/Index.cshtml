@model List<QuizApp.Models.MultipleChoice>

<h2>Multiple Choice Questions</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Add Question</a>
</p>

@foreach (var q in Model)
{
    <div class="card mb-3 shadow-sm">
        <div class="card-body">
            <h4>@q.QuestionText</h4>

            @if (q.Options != null && q.Options.Any())
            {
                <ul class="list-group list-group-flush">
                    @foreach (var opt in q.Options)
                    {
                        <li class="list-group-item">
                            @opt.Text
                            @if (opt.IsCorrect)
                            {
                                <span class="badge bg-success ms-2">Correct</span>
                            }
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No options added yet.</p>
            }

            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@q.Id" class="btn btn-primary btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@q.Id" class="btn btn-danger btn-sm">Delete</a>
            </div>
        </div>
    </div>
}
