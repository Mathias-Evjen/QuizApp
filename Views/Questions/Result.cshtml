@model QuizApp.Models.QuizAttempt
@{
    ViewData["Title"] = "Resultat";
}

<h2>Resultat</h2>
<p>Du fikk @Model.Score av @Model.Total riktige.</p>

@foreach (var a in Model.Answers)
{
    <div>
        <p><b>@a.QuestionText</b></p>
        <p>Dine svar: @string.Join(", ", a.SelectedAnswers)</p>
        <p>Korrekte svar: @string.Join(", ", a.CorrectAnswers)</p>
        <p>@(a.IsCorrect ? "Riktig" : "Feil")</p>
    </div>
}