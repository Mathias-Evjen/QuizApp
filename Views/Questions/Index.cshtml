@model IEnumerable<QuizApp.Models.MultipleChoice>

@{
    ViewData["Title"] = "Multiple Choice Questions";
}

<h2>Multiple Choice Questions</h2>

<p>
    <a class="btn btn-success" asp-action="Create">Add New Question</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Question</th>
            <th>Options</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.QuestionText</td>
                <td>
                    @foreach (var opt in item.Options)
                    {
                        <div>@opt.Text @(opt.IsCorrect ? "(✓)" : "")</div>
                    }
                </td>
                <td>
                    <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
